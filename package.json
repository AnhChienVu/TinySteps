{
  "name": "tinysteps-monorepo",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run start:dev --workspace backend",
    "build:frontend": "npm run build --workspace frontend",
    "build:backend": "npm run build --workspace backend",
    "lint:frontend": "npm run lint --workspace frontend",
    "lint:backend": "npm run lint --workspace backend",
    "typecheck:frontend": "npx tsc -p apps/frontend/tsconfig.json --noEmit",
    "typecheck:backend": "npx tsc -p apps/backend/tsconfig.json --noEmit",
    "build": "npm run build:frontend && npm run build:backend",
    "ci": "npm run lint:frontend && npm run typecheck:frontend && npm run typecheck:backend && npm run build"
  }
}
